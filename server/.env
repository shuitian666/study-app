# Ollama (本地模式, 无需 Key，但需要安装并运行)
# 下载地址: https://ollama.com/
# 安装后运行: ollama pull gemma3:1b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma3:1b

# 火山引擎/豆包 (云端模式) - 需要申请 API Key
# 申请地址: https://console.volcengine.com/ark
VOLC_API_KEY=
VOLC_MODEL_ID=

# Minimax (云端模式) - 需要申请 API Key
# 申请地址: https://platform.minimax.chat/
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=MiniMax-Text-01

# 服务端口
PORT=3001
